# Copy to `.env` for local development.
# Only expose safe public values to the static front-end.

# Public API base used by browser pages in /dist/assets/portal-config.js
PUBLIC_PO_API_BASE=http://localhost:3001

# Portal URLs used by lms-api role redirects.
# For production, point each role to its subdomain.
ADMIN_PORTAL_URL=https://admin.example.com
TUTOR_PORTAL_URL=https://tutor.example.com
STUDENT_PORTAL_URL=https://student.example.com

# API / database configuration
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lms
PUBLIC_BASE_URL=http://localhost:3001
COOKIE_SECRET=change_me_to_a_long_random_string
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,https://admin.example.com,https://tutor.example.com,https://student.example.com
EMAIL_PROVIDER_KEY=
EMAIL_FROM=projectodysseus.maths@gmail.com
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=15m
ADMIN_BOOTSTRAP_TOKEN=change_me
TRUST_PROXY=1
