# Copy to `.env` for local development.
# Only expose safe public values to the static front-end.

# Public API base used by browser pages in /dist/assets/portal-config.js
PUBLIC_PO_API_BASE=http://localhost:3001

# Portal URLs used by lms-api role redirects.
# For production, point each role to its subdomain.
ADMIN_PORTAL_URL=https://admin.example.com
TUTOR_PORTAL_URL=https://tutor.example.com
STUDENT_PORTAL_URL=https://student.example.com

# API / database configuration
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/lms
PUBLIC_BASE_URL=http://localhost:3001
COOKIE_SECRET=change_me_to_a_long_random_string
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,https://admin.example.com,https://tutor.example.com,https://student.example.com,http://127.0.0.1:8081, http://localhost:8081 
EMAIL_PROVIDER_KEY=
EMAIL_FROM=projectodysseus.maths@gmail.com
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=15m
ADMIN_BOOTSTRAP_TOKEN=change_me
TRUST_PROXY=1
ODIE_CAREERS_DEV_BYPASS=true

# Odie assistant configuration
GROQ_API_KEY=replace_with_your_groq_api_key
OPENROUTER_API_KEY=replace_with_your_openrouter_api_key
ODIE_ACCESS_KEYS=replace_with_rotation_key_1,replace_with_rotation_key_2
# Optional: prefill Odie key in browser runtime config for static environments.
PUBLIC_ODIE_ACCESS_KEY=

DEFAULT_MODEL=llama-3.3-70b-versatile
MAX_TOKENS=1024
TEMPERATURE=0.4
