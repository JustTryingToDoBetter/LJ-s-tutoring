{
  "name": "lj-s-tutoring",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "groq-sdk": "^1.1.1",
    "http-server": "^14.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/typography": "^0.5.16",
    "cpy-cli": "^5.0.0",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "html-validate": "^9.5.3",
    "husky": "^9.0.11",
    "jsdom": "^24.0.0",
    "linkinator": "^6.1.2",
    "mkdirp": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "pa11y-ci": "^4.0.1",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.17",
    "vitest": "^2.1.8",
    "wait-on": "^7.2.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean && mkdirp dist/assets dist/assets/admin dist/assets/tutor dist/assets/student dist/guides dist/images dist/admin dist/tutor dist/dashboard dist/reports dist/parent",
    "build:css": "tailwindcss -c tailwind.config.js -i ./assets/tailwind-input.css -o ./dist/assets/tailwind-input.css --minify",
    "build:html": "cpy \"*.html\" dist --flat",
    "build:static": "cpy \"favicon.svg\" \"robots.txt\" \"sitemap.xml\" dist --flat",
    "build:guides": "cpy \"guides/*.html\" dist/guides",
    "build:images": "cpy \"images/*\" dist/images",
    "build:assets": "cpy \"assets/*.js\" dist/assets --flat",
    "build:admin": "cpy \"admin/*.html\" dist/admin",
    "build:admin-assets": "cpy \"assets/admin/**/*.js\" dist/assets/admin",
    "build:tutor": "cpy \"tutor/**/*.html\" dist/tutor",
    "build:parent": "cpy \"parent/**/*.html\" dist/parent",
    "build:tutor-assets": "cpy \"assets/tutor/*.js\" dist/assets/tutor",
    "build:student-assets": "cpy \"assets/student/*.js\" dist/assets/student",
    "build:dashboard": "cpy \"dashboard/**/*.html\" dist/dashboard",
    "build:reports": "cpy \"reports/**/*.html\" dist/reports",
    "inject:config": "node scripts/inject-config.js",
    "build": "npm-run-all --parallel build:css build:html build:static build:guides build:images build:assets build:admin build:admin-assets build:tutor build:parent build:tutor-assets build:student-assets build:dashboard build:reports && npm run inject:config",
    "serve": "http-server dist -p 8080 -c-1",
    "start": "http-server dist -a 0.0.0.0 -p ${PORT:-8080} -c-1",
    "dev:full": "npm-run-all prebuild build:css build:html build:static build:guides build:images build:assets build:admin build:admin-assets build:tutor build:parent build:tutor-assets build:student-assets build:dashboard build:reports inject:config",
    "dev:static": "npm-run-all dev:full serve",
    "dev": "npm run dev:static",
    "lint:js": "eslint \"assets/**/*.js\" \"scripts/**/*.js\"",
    "lint:html": "html-validate \"*.html\" \"guides/*.html\"",
    "lint": "npm-run-all --parallel lint:js lint:html",
    "qa:html": "html-validate \"dist/*.html\" \"dist/guides/*.html\"",
    "qa:links": "linkinator http://localhost:8080 --recurse --timeout 10000 --concurrency 4 --skip \"^mailto:|^tel:|^https?:\\/\\/(?!localhost:8080)\"",
    "qa:a11y": "pa11y-ci",
    "qa:quick": "npm-run-all build && (npm run serve --silent & wait-on http://localhost:8080) && npm-run-all --parallel qa:html qa:links",
    "qa": "npm-run-all build && (npm run serve --silent & wait-on http://localhost:8080) && npm-run-all --parallel qa:html qa:links qa:a11y",
    "prepare": "husky || true"
  }
}
