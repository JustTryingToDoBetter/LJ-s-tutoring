  scoreDate              DateTime @map("score_date") @db.Date
  riskScore              Int      @map("risk_score")
  momentumScore          Int      @map("momentum_score")
  reasonsJson            Json     @map("reasons_json")
  metricsJson            Json     @map("metrics_json")
  recommendedActionsJson Json     @map("recommended_actions_json")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, scoreDate])
  @@index([userId, scoreDate(sort: Desc)])
  @@map("student_score_snapshots")
}

model CommunityProfile {
  userId              String   @id @map("user_id") @db.Uuid
  nickname            String
  privacySettingsJson Json     @map("privacy_settings_json")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("community_profiles")
}

model StudyRoom {
  id        String   @id @default(uuid()) @db.Uuid
  subject   String
  grade     String?
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  memberships StudyRoomMember[]
  messages    StudyRoomMessage[]
  resources   StudyRoomPinnedResource[]

  @@index([subject, grade, createdAt(sort: Desc)])
  @@map("study_rooms")
}

model StudyRoomMember {
  roomId   String   @map("room_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz

  room StudyRoom @relation(fields: [roomId], references: [id])
  user User      @relation(fields: [userId], references: [id])

  @@id([roomId, userId])
  @@index([userId, joinedAt(sort: Desc)])
  @@map("study_room_members")
}

model StudyRoomMessage {
  id              String   @id @default(uuid()) @db.Uuid
  roomId          String   @map("room_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  content         String
  moderationState String   @default("VISIBLE") @map("moderation_state")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  room StudyRoom @relation(fields: [roomId], references: [id])
  user User      @relation(fields: [userId], references: [id])

  @@index([roomId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("study_room_messages")
}

model StudyRoomPinnedResource {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @map("room_id") @db.Uuid
  title     String
  url       String
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  room StudyRoom @relation(fields: [roomId], references: [id])

  @@index([roomId, createdAt(sort: Desc)])
  @@map("study_room_pinned_resources")
}

model Challenge {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  subject   String
  grade     String?
  weekStart DateTime @map("week_start") @db.Date
  weekEnd   DateTime @map("week_end") @db.Date
  xpReward  Int      @map("xp_reward")
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  creator     User                  @relation("challenge_creator", fields: [createdBy], references: [id])
  submissions ChallengeSubmission[]

  @@index([weekStart, weekEnd])
  @@index([subject, grade, createdAt(sort: Desc)])
  @@map("challenges")
}

model ChallengeSubmission {
  id          String   @id @default(uuid()) @db.Uuid
  challengeId String   @map("challenge_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  content     String
  score       Int?
  feedback    String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  challenge Challenge @relation(fields: [challengeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([challengeId, userId])
  @@index([challengeId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("challenge_submissions")
}

model Question {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  subject         String
  topic           String
  title           String
  body            String
  status          String   @default("OPEN")
  moderationState String   @default("VISIBLE") @map("moderation_state")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    User     @relation(fields: [userId], references: [id])
  answers Answer[]

  @@index([subject, topic, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("questions")
}

model Answer {
  id              String   @id @default(uuid()) @db.Uuid
  questionId      String   @map("question_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  body            String
  isVerified      Boolean  @default(false) @map("is_verified")
  verifiedBy      String?  @map("verified_by") @db.Uuid
  moderationState String   @default("VISIBLE") @map("moderation_state")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  question Question @relation(fields: [questionId], references: [id])
  author   User     @relation("answer_author", fields: [userId], references: [id])
  verifier User?    @relation("answer_verifier", fields: [verifiedBy], references: [id])

  @@index([questionId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("answers")
}

model CommunityReport {
  id         String   @id @default(uuid()) @db.Uuid
  reporterId String   @map("reporter_id") @db.Uuid
  targetType String   @map("target_type")
  targetId   String   @map("target_id") @db.Uuid
  reason     String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  reporter User @relation("community_reporter", fields: [reporterId], references: [id])

  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@index([reporterId, createdAt(sort: Desc)])
  @@map("community_reports")
}

model CommunityBlock {
  blockerUserId String   @map("blocker_user_id") @db.Uuid
  blockedUserId String   @map("blocked_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  blocker User @relation("community_blocker", fields: [blockerUserId], references: [id])
  blocked User @relation("community_blocked", fields: [blockedUserId], references: [id])

  @@id([blockerUserId, blockedUserId])
  @@index([blockedUserId, blockerUserId])
  @@map("community_blocks")
}

model CareerGoalSelection {
