{
  "name": "lms-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:test": "tsx src/index.ts",
    "db:create:local": "tsx scripts/create-local-db.ts",
    "migrate": "tsx src/db/migrate.ts",
    "seed:dev": "tsx scripts/seed-dev.ts",
    "db:migrate:test": "node scripts/run-with-test-env.js tsx src/db/migrate.ts",
    "db:reset:test": "node scripts/run-with-test-env.js tsx scripts/reset-test-db.ts",
    "seed:test": "node scripts/run-with-test-env.js tsx scripts/seed-test.ts",
    "retention:cleanup": "tsx scripts/retention-cleanup.ts",
    "retention:queue": "tsx scripts/queue-retention-cleanup.ts",
    "job:worker": "tsx scripts/job-worker.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:validate": "prisma validate",
    "test": "node scripts/run-with-test-env.js npm run db:migrate:test && node scripts/run-with-test-env.js vitest run --exclude tests/e2e/**",
    "test:contracts": "node scripts/run-with-test-env.js vitest run tests/contracts",
    "test:e2e": "cross-env NODE_ENV=test vitest run tests/e2e",
    "test:ci": "node scripts/run-with-test-env.js npm run db:migrate:test && node scripts/run-with-test-env.js vitest run --exclude tests/e2e/** --reporter=default --reporter=junit --outputFile=test-results/unit-junit.xml",
    "test:e2e:ci": "cross-env NODE_ENV=test vitest run tests/e2e --reporter=default --reporter=junit --outputFile=test-results/e2e-junit.xml",
    "odie:refresh-cache": "tsx scripts/refresh-odie-careers-cache.ts",
    "schema:check": "tsx scripts/check-schema-governance.ts",
    "restore:verify": "tsx scripts/restore-verify.ts",
    "db:maintenance:check": "tsx scripts/check-db-maintenance.ts",
    "db:maintenance:check:strict": "cross-env DB_MAINTENANCE_STRICT=true tsx scripts/check-db-maintenance.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/oauth2": "^8.2.0",
    "@fastify/rate-limit": "^10.0.0",
    "@prisma/client": "^6.3.1",
    "ajv": "^8.18.0",
    "argon2": "^0.40.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.0.0",
    "nodemailer": "^8.0.3",
    "pdfkit": "^0.16.0",
    "pg": "^8.12.0",
    "pino": "^9.6.0",
    "qs": "^6.15.0",
    "zod": "^3.23.8",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.16.0",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
