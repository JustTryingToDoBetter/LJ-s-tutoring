{
  "id": null,
  "uid": "project-odysseus-api-overview",
  "title": "Project Odysseus API Overview",
  "tags": ["project-odysseus", "api", "slo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(po_requests_total[5m]))"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(po_requests_error_total[5m])) / clamp_min(sum(rate(po_requests_total[5m])), 1))"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Slow Request Ratio (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(po_requests_slow_total[5m])) / clamp_min(sum(rate(po_requests_total[5m])), 1))"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Requests (1h)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(po_requests_total[1h]))"
        }
      ]
    }
  ]
}
